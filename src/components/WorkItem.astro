---
import TagChip from "~/components/TagChip.astro";
import { type NavItem } from "~/data/navigation";

type Props = NavItem;

const { title, href, description, tags } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener noreferrer"
  class="reveal flex h-full flex-col rounded-xl border border-white/10 p-5 text-start transition-colors hover:border-indigo-500/40 hover:bg-white/5"
>
  <h4 class="text-lg font-bold leading-snug text-indigo-400">{title}</h4>
  {
    tags && tags.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-1.5">
        {tags.map((tag) => (
          <TagChip label={tag} />
        ))}
      </div>
    )
  }
  <p class="mt-3 text-sm leading-relaxed text-gray-300">{description}</p>
</a>
