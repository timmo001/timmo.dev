---
import { getTagStyle } from "~/data/tag-styles";
import { getContrastColor, getRGBColorFromHex } from "~/lib/color";

type Props = {
  tags: Array<string>;
  stack: Array<string>;
};

type Chip = {
  label: string;
  value: string;
  backgroundColor: string;
  textColor: string;
};

type Picker = {
  key: "tag" | "stack";
  label: string;
  chips: Array<Chip>;
};

const { tags, stack } = Astro.props;

function toChip(label: string): Chip {
  const { backgroundColor } = getTagStyle(label);
  return {
    label,
    value: label.toLowerCase(),
    backgroundColor,
    textColor: getContrastColor(getRGBColorFromHex(backgroundColor)),
  };
}

const pickers: Array<Picker> = [
  { key: "tag", label: "Tags", chips: tags.map(toChip) },
  { key: "stack", label: "Stack", chips: stack.map(toChip) },
];

const optionClass =
  "flex w-full items-center gap-2 rounded-md px-2 py-1.5 text-left text-sm text-gray-200 transition-colors hover:bg-white/10 aria-pressed:bg-white/10 aria-pressed:text-white";
---

<div
  class="flex w-full flex-col gap-3 sm:flex-row sm:items-center"
  data-project-filters
>
  <div class="relative w-full sm:flex-1">
    <label for="project-search" class="sr-only">Search projects</label>
    <svg
      class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-gray-400"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <circle cx="11" cy="11" r="8"></circle>
      <path d="m21 21-4.3-4.3"></path>
    </svg>
    <input
      id="project-search"
      type="search"
      placeholder="Filter..."
      autocomplete="off"
      class="w-full rounded-full border border-white/15 bg-white/5 py-2.5 pl-10 pr-4 text-sm text-gray-100 placeholder:text-gray-500 transition-colors focus:border-indigo-500/60 focus:outline-none"
      data-filter-search
    />
  </div>

  <div class="flex gap-3">
    {
      pickers.map((picker) => (
        <div class="relative flex-1 sm:w-48 sm:flex-none" data-picker={picker.key}>
          <button
            type="button"
            class="flex w-full items-center justify-between gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-2.5 text-sm text-gray-200 transition-colors hover:border-indigo-500/40 aria-expanded:border-indigo-500/60"
            aria-expanded="false"
            aria-haspopup="listbox"
            data-picker-trigger
          >
            <span class="flex items-center gap-2">
              {picker.label}
              <span
                class="hidden min-w-5 items-center justify-center rounded-full bg-indigo-500/80 px-1.5 text-xs font-semibold text-white"
                data-picker-count
              >
                0
              </span>
            </span>
            <svg
              class="h-4 w-4 text-gray-400"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="m6 9 6 6 6-6" />
            </svg>
          </button>

          <div
            class="absolute left-0 right-0 top-full z-20 mt-2 hidden flex-col gap-2 rounded-md border border-white/15 bg-[#0d0d12] p-2 shadow-xl"
            data-picker-panel
          >
            <input
              type="search"
              placeholder={`Search ${picker.label.toLowerCase()}...`}
              autocomplete="off"
              class="w-full rounded-full border border-white/10 bg-white/5 px-3 py-1.5 text-xs text-gray-100 placeholder:text-gray-500 focus:border-indigo-500/60 focus:outline-none"
              data-picker-search
            />
            <ul class="flex max-h-64 flex-col gap-0.5 overflow-y-auto" data-picker-list>
              {picker.chips.map((chip) => (
                <li data-picker-option data-label={chip.label.toLowerCase()}>
                  <button
                    type="button"
                    class={optionClass}
                    aria-pressed="false"
                    {...(picker.key === "tag"
                      ? { "data-filter-tag": chip.value }
                      : { "data-filter-stack": chip.value })}
                  >
                    <span
                      class="h-2.5 w-2.5 shrink-0 rounded-full"
                      style={`background-color: ${chip.backgroundColor}`}
                    />
                    {chip.label}
                  </button>
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))
    }
  </div>

  <button
    type="button"
    class="hidden items-center gap-1.5 text-xs font-medium text-gray-400 transition-colors hover:text-white"
    data-filter-reset
  >
    <svg
      class="h-3.5 w-3.5"
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden="true"
    >
      <path d="M18 6 6 18"></path>
      <path d="m6 6 12 12"></path>
    </svg>
    Clear
  </button>
</div>

<p
  class="hidden text-center text-sm text-gray-400"
  data-filter-empty
  role="status"
>
  No matching projects.
</p>
