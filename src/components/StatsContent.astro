---
import GitHubStats from "~/components/GitHubStats.astro";
import SubpageHeader from "~/components/SubpageHeader.astro";
import TopLanguages from "~/components/TopLanguages.astro";
import { formatDateTimeFallback } from "~/lib/dates";
import { STATS_CACHE_TTL_LABEL } from "~/lib/stats-cache";
import type { Language } from "~/types/github/language";
import type { Stat } from "~/types/github/stat";

type Props = {
  githubStats: Array<Stat>;
  githubTopLanguages: Array<Language>;
  fetchedAt: Date;
};

const { githubStats, githubTopLanguages, fetchedAt } = Astro.props;
---

<SubpageHeader title="Stats" />
<div
  class="flex w-full flex-col items-center justify-start px-4 py-16"
  role="main"
>
  <div class="container flex w-full flex-col items-center gap-16 text-center">
    <section>
      <div
        class="stagger-stats grid grid-cols-2 gap-12 leading-snug tracking-tight sm:grid-cols-3 md:grid-cols-4"
      >
        <GitHubStats stats={githubStats} />
      </div>
    </section>

    <section>
      <h3
        class="reveal mb-4 text-2xl leading-snug font-normal tracking-tight text-white"
      >
        Top Languages
      </h3>
      <div
        class="grid grid-cols-3 gap-4 leading-snug tracking-tight sm:grid-cols-4 md:grid-cols-5 lg:grid-cols-6"
      >
        <TopLanguages languages={githubTopLanguages} />
      </div>
    </section>

    <section>
      <h3
        class="reveal mb-4 text-2xl leading-snug font-normal tracking-tight text-white"
      >
        Contribution Graph
      </h3>
      <div class="reveal">
        <iframe
          src="https://ghchart.rshah.org/timmo001"
          title="timmo001"
          height="120"
          width="670"
          style="border: 0; background: transparent !important"></iframe>
      </div>
    </section>
  </div>
</div>
<section
  aria-label="Cache status"
  class="flex w-full flex-col items-center gap-1 px-4 pb-6 text-center text-muted-foreground"
>
  <p class="text-sm">
    Last updated{" "}
    <time datetime={fetchedAt.toISOString()} data-local-time>
      {formatDateTimeFallback(fetchedAt)}
    </time>
  </p>
  <p class="max-w-md text-xs leading-snug text-muted-foreground/70">
    Cached for {STATS_CACHE_TTL_LABEL} across GraphQL, server memory, and the CDN.
  </p>
</section>
