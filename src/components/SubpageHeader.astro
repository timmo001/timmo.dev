---
type Props = {
  title: string;
  showSubtitle?: boolean;
};

const { title, showSubtitle = true } = Astro.props;
const letters = [...title];
---

<header
  class="relative h-[50vh] min-h-96 w-full overflow-hidden bg-linear-to-b from-violet-900 to-gray-950 p-4"
  role="banner"
>
  <div
    class="relative z-10 flex h-full w-full max-w-screen flex-col items-start justify-end bg-contain bg-center bg-no-repeat p-8 md:p-16"
    style="background-image: url('/logo-wide-nobackground.png')"
  >
    <div class="flex flex-wrap items-baseline justify-start text-start">
      <h1 class="me-6 text-8xl leading-none font-bold tracking-tight text-white">
        {
          letters.map((letter, index) => (
            <span
              class="hero-letter inline-block"
              style={`animation-delay: ${index * 0.03}s`}
            >
              {letter === " " ? "\u00A0" : letter}
            </span>
          ))
        }
      </h1>
      {
        showSubtitle && (
          <span
            class="hero-reveal text-4xl leading-none font-bold tracking-normal text-nowrap"
            style="animation-delay: 0.4s"
          >
            <span class="text-indigo-400">Timmo</span> /{" "}
            <span class="text-indigo-400">@timmo001</span>
          </span>
        )
      }
    </div>
  </div>
</header>
