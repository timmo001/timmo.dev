---
import AnimatedText from "~/components/AnimatedText.astro";

type Props = {
  title: string;
};

const { title } = Astro.props;
---

<header
  class="relative h-[50svh] min-h-72 w-full overflow-x-clip bg-linear-to-b from-violet-900 to-gray-950 p-4 sm:min-h-96"
  role="banner"
>
  <div
    class="relative z-10 flex h-full w-full max-w-screen flex-col items-start justify-end bg-contain bg-center bg-no-repeat px-4 pt-4 sm:px-8 sm:pt-8 md:px-16 md:pt-16"
    style="background-image: url('/logo-wide-nobackground.png')"
  >
    <div class="w-full min-w-0 text-start">
      <h1 class="hero-title">
        <AnimatedText text={title} />
      </h1>
    </div>
  </div>
</header>
