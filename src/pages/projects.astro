---
import SectionBlock from "~/components/SectionBlock.astro";
import SubpageHeader from "~/components/SubpageHeader.astro";
import MasonryGrid from "~/components/MasonryGrid.astro";
import WorkItem from "~/components/WorkItem.astro";
import Layout from "~/layouts/Layout.astro";
import { contributions, projects as staticProjects } from "~/data/navigation";
import { mergeProjectsWithHaGitHub } from "~/lib/ha-projects";

const projects = await mergeProjectsWithHaGitHub(staticProjects);
---

<Layout
  title="Projects & contributions | Aidan Timson (Timmo)"
  description="What I'm building and contributing to. Projects and open-source work by Aidan Timson (Timmo/timmo001)"
>
  <SubpageHeader title="Projects & contributions" />
  <div
    class="flex w-full flex-col items-center justify-start px-4 py-16"
    role="main"
  >
    <div class="container flex w-full flex-col gap-36 px-2">
      <section aria-labelledby="building-heading" class="flex flex-col gap-16">
        <div class="grid gap-x-4 gap-y-8 md:grid-cols-2">
          <h3
            id="building-heading"
            class="reveal section-heading"
          >
            What I'm building
          </h3>
          <div class="reveal">
            <SectionBlock>
              I like making things that solve problems I actually have, including desktop
              apps, home automation tools, developer utilities, and side projects
              that often start as "can this be a thing?".
              <br />
              <br />
              Sometimes there's a clear reason. Sometimes I'm just curious about a
              language or framework and want to learn by using it.
            </SectionBlock>
          </div>
        </div>

        <MasonryGrid class="stagger-grid">
          {projects.map((item) => <WorkItem {...item} />)}
        </MasonryGrid>
      </section>

      <section
        aria-labelledby="contributing-heading"
        class="border-t border-white/10 pt-36"
      >
        <div class="flex flex-col gap-16">
          <div class="grid gap-x-4 gap-y-8 md:grid-cols-2">
            <h3
              id="contributing-heading"
              class="reveal section-heading"
            >
              What I contribute to
            </h3>
            <div class="reveal">
              <SectionBlock>
                Most of my contributions sit in the{" "}
                <a
                  class="text-link"
                  href="https://www.home-assistant.io"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Home Assistant
                </a>{" "}
                ecosystem: core integrations, community add-ons, and supporting
                tooling for my own projects.
              </SectionBlock>
            </div>
          </div>

          <MasonryGrid class="stagger-grid">
            {contributions.map((item) => <WorkItem {...item} />)}
          </MasonryGrid>
        </div>
      </section>
    </div>
  </div>
</Layout>
