---
import ProjectFilters from "~/components/ProjectFilters.astro";
import SectionBlock from "~/components/SectionBlock.astro";
import SubpageHeader from "~/components/SubpageHeader.astro";
import WorkItem from "~/components/WorkItem.astro";
import Layout from "~/layouts/Layout.astro";
import { contributions, projects as staticProjects, type NavItem } from "~/data/navigation";
import { sortStack } from "~/data/stack-sort";
import { sortTags } from "~/data/tag-sort";
import { mergeIntegrationsWithGitHub } from "~/lib/ha-integrations";
import { mergeProjectsWithHaGitHub } from "~/lib/ha-projects";

const { projects, haProjects, haGitHubSynced } =
  await mergeProjectsWithHaGitHub(staticProjects);

function isArchivedItem(item: NavItem): boolean {
  return item.tags?.includes("Archive") ?? false;
}

function sortArchivedLast(items: Array<NavItem>): Array<NavItem> {
  return items.toSorted(
    (left, right) => Number(isArchivedItem(left)) - Number(isArchivedItem(right)),
  );
}

function hasHacsTag(item: NavItem): boolean {
  return item.tags?.includes("HACS") ?? false;
}

function dedupeByHref(items: Array<NavItem>): Array<NavItem> {
  const seen = new Set<string>();

  return items.filter((item) => {
    if (seen.has(item.href)) {
      return false;
    }

    seen.add(item.href);
    return true;
  });
}

const frontendContribution = contributions.find(
  (item) => item.href === "https://github.com/home-assistant/frontend",
);
const staticIntegrations = contributions.filter(
  (item) => item.href !== "https://github.com/home-assistant/frontend",
);

const { integrations: rawIntegrationItems, integrationsSynced } =
  await mergeIntegrationsWithGitHub(staticIntegrations);
const integrationItems = sortArchivedLast(rawIntegrationItems);

const leadingHaItems = sortArchivedLast(
  dedupeByHref([
    ...(frontendContribution ? [frontendContribution] : []),
    ...haProjects.filter((item) => !hasHacsTag(item)),
  ]),
);

const hacsItems = sortArchivedLast(dedupeByHref(haProjects.filter(hasHacsTag)));

const homeAssistantHrefs = new Set(
  [...leadingHaItems, ...hacsItems, ...integrationItems].map(
    (item) => item.href,
  ),
);
const contributionHrefs = new Set(contributions.map((item) => item.href));

const activeProjects = sortArchivedLast(
  projects.filter(
    (item) =>
      !homeAssistantHrefs.has(item.href) && !contributionHrefs.has(item.href),
  ),
);

const hasHomeAssistantSection =
  leadingHaItems.length > 0 ||
  hacsItems.length > 0 ||
  integrationItems.length > 0;

const filterableItems = [
  ...activeProjects,
  ...leadingHaItems,
  ...hacsItems,
  ...integrationItems,
];

const filterTags = sortTags([
  ...new Set(filterableItems.flatMap((item) => item.tags ?? [])),
]).toSorted(
  (left, right) => Number(left === "Archive") - Number(right === "Archive"),
);
const filterStack = sortStack([
  ...new Set(filterableItems.flatMap((item) => item.stack ?? [])),
]);
---

<Layout
  title="Projects & contributions | Aidan Timson (Timmo)"
  description="What I'm building and contributing to. Projects and open-source work by Aidan Timson (Timmo/timmo001)"
>
  <SubpageHeader title="Projects & contributions" />
  <div
    class="flex w-full flex-col items-center justify-start px-4 py-16"
    role="main"
  >
    <div class="container flex w-full flex-col gap-36 px-2">
      <section aria-label="Introduction" class="flex flex-col gap-8">
        <div class="reveal px-6 md:px-12">
          <SectionBlock>
            Most of my open-source work is in{" "}
            <a
              class="text-link"
              href="https://www.home-assistant.io"
              target="_blank"
              rel="noopener noreferrer"
            >
              Home Assistant
            </a>
            . I am one of the core maintainers of the{" "}
            <a
              class="text-link"
              href="https://github.com/home-assistant/frontend"
              target="_blank"
              rel="noopener noreferrer"
            >
              frontend
            </a>{" "}
            for the{" "}
            <a
              class="text-link"
              href="https://www.openhomefoundation.org"
              target="_blank"
              rel="noopener noreferrer"
            >
              Open Home Foundation
            </a>
            , and I also contribute to{" "}
            <a
              class="text-link"
              href="https://www.home-assistant.io/getting-started/concepts-terminology/#integrations"
              target="_blank"
              rel="noopener noreferrer"
            >
              integrations
            </a>{" "}
            and the community with{" "}
            <a
              class="text-link"
              href="https://www.home-assistant.io/dashboards/"
              target="_blank"
              rel="noopener noreferrer"
            >
              dashboards
            </a>
            ,{" "}
            <a
              class="text-link"
              href="https://developers.home-assistant.io/docs/frontend/custom-ui/custom-strategy"
              target="_blank"
              rel="noopener noreferrer"
            >
              community dashboards
            </a>
            ,{" "}
            <a
              class="text-link"
              href="https://developers.home-assistant.io/docs/frontend/custom-ui/custom-card/"
              target="_blank"
              rel="noopener noreferrer"
            >
              cards
            </a>
            , and{" "}
            <a
              class="text-link"
              href="https://www.home-assistant.io/getting-started/concepts-terminology/#apps"
              target="_blank"
              rel="noopener noreferrer"
            >
              apps
            </a>
            .
          </SectionBlock>
        </div>

        <ProjectFilters tags={filterTags} stack={filterStack} />

        <div
          class="stagger-grid grid items-start gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
          data-filter-group="active"
        >
          {activeProjects.map((item) => <WorkItem {...item} />)}
        </div>

        {
          hasHomeAssistantSection ? (
            <div class="flex flex-col gap-8" data-filter-section>
              <h4
                id="home-assistant-heading"
                class="reveal subsection-heading"
              >
                Home Assistant
              </h4>

              {
                leadingHaItems.length > 0 ? (
                  <div
                    class="stagger-grid grid items-start gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
                    data-filter-group="ha-leading"
                  >
                    {leadingHaItems.map((item) => <WorkItem {...item} />)}
                  </div>
                ) : null
              }

              {
                hacsItems.length > 0 ? (
                  <div class="flex flex-col gap-6" data-filter-group="ha-hacs">
                    <h5
                      id="community-heading"
                      class="reveal subsubsection-heading inline-flex items-center gap-2"
                    >
                      Community Dashboards and Cards
                      <span
                        class:list={[
                          "inline-flex",
                          haGitHubSynced ? "text-white/25" : "text-white/15",
                        ]}
                        title={
                          haGitHubSynced
                            ? "Synced from GitHub"
                            : "Static fallback"
                        }
                        aria-label={
                          haGitHubSynced
                            ? "Synced from GitHub"
                            : "Static fallback"
                        }
                      >
                        <svg
                          class="h-3.5 w-3.5 fill-current"
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24"
                          aria-hidden="true"
                        >
                          <path d="M12,2A10,10 0 0,0 2,12C2,16.42 4.87,20.17 8.84,21.5C9.34,21.58 9.5,21.27 9.5,21C9.5,20.77 9.5,20.14 9.5,19.31C6.73,19.91 6.14,17.97 6.14,17.97C5.68,16.81 5.03,16.5 5.03,16.5C4.12,15.88 5.1,15.9 5.1,15.9C6.1,15.97 6.63,16.93 6.63,16.93C7.5,18.45 8.97,18 9.54,17.76C9.63,17.11 9.89,16.67 10.17,16.42C7.95,16.17 5.62,15.31 5.62,11.5C5.62,10.39 6,9.5 6.65,8.79C6.55,8.54 6.2,7.5 6.75,6.15C6.75,6.15 7.59,5.88 9.5,7.17C10.29,6.95 11.15,6.84 12,6.84C12.85,6.84 13.71,6.95 14.5,7.17C16.41,5.88 17.25,6.15 17.25,6.15C17.8,7.5 17.45,8.54 17.35,8.79C18,9.5 18.38,10.39 18.38,11.5C18.38,15.32 16.04,16.16 13.81,16.41C14.17,16.72 14.5,17.33 14.5,18.26C14.5,19.6 14.5,20.68 14.5,21C14.5,21.27 14.66,21.59 15.17,21.5C19.14,20.16 22,16.42 22,12A10,10 0 0,0 12,2Z" />
                        </svg>
                      </span>
                    </h5>
                    <div
                      class="stagger-grid grid items-start gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
                    >
                      {hacsItems.map((item) => <WorkItem {...item} />)}
                    </div>
                  </div>
                ) : null
              }

              {
                integrationItems.length > 0 ? (
                  <div class="flex flex-col gap-6" data-filter-group="ha-integrations">
                    <h5
                      id="integrations-heading"
                      class="reveal subsubsection-heading inline-flex items-center gap-2"
                    >
                      Integrations
                      <span
                        class:list={[
                          "inline-flex",
                          integrationsSynced ? "text-white/25" : "text-white/15",
                        ]}
                        title={
                          integrationsSynced
                            ? "Synced from GitHub"
                            : "Static fallback"
                        }
                        aria-label={
                          integrationsSynced
                            ? "Synced from GitHub"
                            : "Static fallback"
                        }
                      >
                        <svg
                          class="h-3.5 w-3.5 fill-current"
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24"
                          aria-hidden="true"
                        >
                          <path d="M12,2A10,10 0 0,0 2,12C2,16.42 4.87,20.17 8.84,21.5C9.34,21.58 9.5,21.27 9.5,21C9.5,20.77 9.5,20.14 9.5,19.31C6.73,19.91 6.14,17.97 6.14,17.97C5.68,16.81 5.03,16.5 5.03,16.5C4.12,15.88 5.1,15.9 5.1,15.9C6.1,15.97 6.63,16.93 6.63,16.93C7.5,18.45 8.97,18 9.54,17.76C9.63,17.11 9.89,16.67 10.17,16.42C7.95,16.17 5.62,15.31 5.62,11.5C5.62,10.39 6,9.5 6.65,8.79C6.55,8.54 6.2,7.5 6.75,6.15C6.75,6.15 7.59,5.88 9.5,7.17C10.29,6.95 11.15,6.84 12,6.84C12.85,6.84 13.71,6.95 14.5,7.17C16.41,5.88 17.25,6.15 17.25,6.15C17.8,7.5 17.45,8.54 17.35,8.79C18,9.5 18.38,10.39 18.38,11.5C18.38,15.32 16.04,16.16 13.81,16.41C14.17,16.72 14.5,17.33 14.5,18.26C14.5,19.6 14.5,20.68 14.5,21C14.5,21.27 14.66,21.59 15.17,21.5C19.14,20.16 22,16.42 22,12A10,10 0 0,0 12,2Z" />
                        </svg>
                      </span>
                    </h5>
                    <div
                      class="stagger-grid grid items-start gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
                    >
                      {integrationItems.map((item) => <WorkItem {...item} />)}
                    </div>
                  </div>
                ) : null
              }
            </div>
          ) : null
        }

      </section>
    </div>
  </div>
</Layout>

<script>
  import { initProjectFilter } from "~/scripts/project-filter";

  initProjectFilter();
  document.addEventListener("astro:page-load", initProjectFilter);
</script>
