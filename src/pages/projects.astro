---
import SectionBlock from "~/components/SectionBlock.astro";
import SubpageHeader from "~/components/SubpageHeader.astro";
import WorkItem from "~/components/WorkItem.astro";
import Layout from "~/layouts/Layout.astro";
import { contributions, projects } from "~/data/navigation";
---

<Layout
  title="Projects & contributions | Aidan Timson (Timmo)"
  description="Pinned projects and open-source contributions by Aidan Timson (Timmo). I am one of the core maintainers of the Home Assistant frontend for the Open Home Foundation."
>
  <SubpageHeader title="Projects & contributions" />
  <div
    class="flex w-full flex-col items-center justify-start px-4 py-16"
    role="main"
  >
    <div class="container flex w-full flex-col gap-36 px-2">
      <section aria-labelledby="building-heading" class="flex flex-col gap-16">
        <div class="grid gap-x-4 gap-y-8 md:grid-cols-2">
          <h3
            id="building-heading"
            class="reveal text-3xl leading-snug font-bold tracking-tight text-white"
          >
            What I'm building
          </h3>
          <div class="reveal">
            <SectionBlock>
              I like making things that solve problems I actually have — desktop
              apps, home automation utilities, dotfiles, and side projects that
              often start as "can this be a thing?".
              <br />
              <br />
              My pinned repositories on{" "}
              <a
                class="text-link"
                href="https://github.com/timmo001"
                target="_blank"
                rel="noopener noreferrer"
                aria-label="GitHub profile"
              >
                GitHub
              </a>{" "}
              are a good snapshot of what I am building right now. Sometimes
              there is a clear reason; sometimes I want to learn a language or
              framework by using it.
            </SectionBlock>
          </div>
        </div>

        <div
          class="stagger-grid grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
        >
          {projects.map((item) => <WorkItem {...item} />)}
        </div>
      </section>

      <section
        aria-labelledby="contributing-heading"
        class="border-t border-white/10 pt-36"
      >
        <div class="flex flex-col gap-16">
          <div class="grid gap-x-4 gap-y-8 md:grid-cols-2">
            <h3
              id="contributing-heading"
              class="reveal text-3xl leading-snug font-bold tracking-tight text-white"
            >
              What I contribute to
            </h3>
            <div class="reveal">
              <SectionBlock>
                I am one of the core maintainers of the{" "}
                <a
                  class="text-link"
                  href="https://github.com/home-assistant/frontend"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Home Assistant frontend
                </a>{" "}
                for the{" "}
                <a
                  class="text-link"
                  href="https://www.openhomefoundation.org/"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Open Home Foundation
                </a>
                , alongside other core integrations in the{" "}
                <a
                  class="text-link"
                  href="https://www.home-assistant.io"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Home Assistant
                </a>{" "}
                ecosystem.
              </SectionBlock>
            </div>
          </div>

          <div
            class="stagger-grid grid gap-6 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4"
          >
            {contributions.map((item) => <WorkItem {...item} />)}
          </div>
        </div>
      </section>
    </div>
  </div>
</Layout>
