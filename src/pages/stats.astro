---
export const prerender = false;

import StatsContent from "~/components/StatsContent.astro";
import StatsLoading from "~/components/StatsLoading.astro";
import Layout from "~/layouts/Layout.astro";

const STATS_CACHE_SECONDS = 60 * 60;

Astro.response.headers.set(
  "Cache-Control",
  `public, s-maxage=${STATS_CACHE_SECONDS}, stale-while-revalidate=${STATS_CACHE_SECONDS * 24}`,
);
---

<Layout
  title="Stats | Aidan Timson (Timmo)"
  description="Aggregated stats for Aidan Timson (Timmo/timmo001)"
>
  <StatsContent server:defer>
    <StatsLoading slot="fallback" />
  </StatsContent>
</Layout>
