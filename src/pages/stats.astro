---
export const prerender = false;

import StatsContent from "~/components/StatsContent.astro";
import Layout from "~/layouts/Layout.astro";
import { getStats, getTopLanguages, getUsername } from "~/lib/github";
import { STATS_CACHE_TTL_SECONDS } from "~/lib/stats-cache";
import { getUserData } from "~/server/github";

const { user, fetchedAt } = await getUserData(getUsername());
const githubStats = getStats(user);
const githubTopLanguages = getTopLanguages(user);

Astro.response.headers.set(
  "Cache-Control",
  `public, s-maxage=${STATS_CACHE_TTL_SECONDS}, stale-while-revalidate=${STATS_CACHE_TTL_SECONDS * 24}`,
);
---

<Layout
  title="Stats | Aidan Timson (Timmo)"
  description="Aggregated stats for Aidan Timson (Timmo/timmo001)"
>
  <StatsContent {githubStats} {githubTopLanguages} {fetchedAt} />
</Layout>

<script>
  import { formatCacheTimes } from "~/scripts/format-cache-times";

  let formatTimer: ReturnType<typeof setTimeout>;

  function scheduleFormatCacheTimes(): void {
    clearTimeout(formatTimer);
    formatTimer = setTimeout(() => {
      void formatCacheTimes();
    }, 0);
  }

  scheduleFormatCacheTimes();
  document.addEventListener("astro:page-load", scheduleFormatCacheTimes);

  const main = document.querySelector("main");
  if (main) {
    new MutationObserver(scheduleFormatCacheTimes).observe(main, {
      childList: true,
      subtree: true,
    });
  }
</script>
