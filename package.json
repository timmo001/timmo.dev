    "deploy:dry-run": "pnpm build && wrangler deploy --dry-run",
    "deploy:preview": "wrangler versions upload",
    "typecheck": "astro check",
    "format": "prettier --plugin=prettier-plugin-astro --check package.json astro.config.mjs wrangler.jsonc README.md AGENTS.md pnpm-workspace.yaml src/env.ts src/layouts/Layout.astro src/components/StatsContent.astro",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^14.1.3",
    "@astrojs/sitemap": "^3.7.3",
    "@tailwindcss/vite": "^4.3.2",
